---
const { isIndex = true } = Astro.props;
const homeLink = '/#home';
const articlesLink = '/articles.html';
const aboutLink = '/#about';
const contactLink = '/#contact';
---
<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="Aoitsuki 首页">
      <img src="/images/my-avatar.jpg" alt="Aoitsuki 头像" class="brand__avatar" />
      <span class="brand__copy">
        <span class="brand__title">Aoitsuki</span>
        <span class="brand__subtitle">{isIndex ? '乌幕屏，海相续，举眼茫茫' : '文字、思考与缓慢生长'}</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      <a href={homeLink}>首页</a>
      <a href={articlesLink}>我的文章</a>
      <a href={aboutLink}>关于我</a>
      <a href={contactLink}>联系</a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="切换主题">☀️</button>
    </nav>
  </div>
</header>
