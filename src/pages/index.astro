---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="我的个人博客"
  description="Aoitsuki 的个人博客首页，记录技术学习、算法思考、生活随笔与留言。"
  isIndex={true}
  pageClass="page-home"
>
  <Fragment slot="head">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  </Fragment>

  <section id="home" class="page-shell">
    <div class="page-shell__inner">
      <div class="panel hero-panel">
        <div class="hero-panel__content">
          <span class="hero-panel__eyebrow">Notebook</span>
          <div class="hero-grid">
            <div>
              <h1 class="hero-title">Aoitsuki</h1>
              <p class="hero-subtitle" id="typewriter-text"></p>
              <noscript>
                <p class="hero-subtitle">乌幕屏，海相续，举眼茫茫，静听细浪语</p>
              </noscript>
              <div class="hero-actions">
                <a href="/articles.html" class="btn btn-primary">📖 阅读最新文章</a>
                <a href="#about" class="btn btn-secondary">🧑‍💻 关于我</a>
              </div>
            </div>
            <figure class="hero-visual">
              <img src="/images/img_1774022028502.png" alt="博客首页头图" class="hero-visual__image" />
            </figure>
          </div>
        </div>
      </div>

      <section id="blog" class="panel section-panel">
        <div class="section-header">
          <div>
            <span class="panel-kicker">Latest</span>
            <h2 class="section-title">最新文章</h2>
          </div>
          <a href="/articles.html" class="btn btn-secondary">查看全部文章</a>
        </div>
        <div class="cards-grid" id="latest-articles">
          <p class="panel-empty">加载中...</p>
        </div>
      </section>

      <div class="grid-two">
        <section id="categories" class="panel section-panel">
          <div class="section-header">
            <div>
              <span class="panel-kicker">Topics</span>
              <h2 class="section-title">知识专栏</h2>
            </div>
          </div>
          <div class="cards-grid" id="dynamic-categories-grid">
            <p class="panel-empty">加载中...</p>
          </div>
        </section>

        <section id="about" class="panel section-panel">
          <div class="section-header">
            <div>
              <span class="panel-kicker">About</span>
              <h2 class="section-title">关于我</h2>
            </div>
          </div>
          <div class="contact-card">
            <div>
              <p>一名富有人文情怀的工科生</p>
              <p>一名勇于实践的理想主义者</p>
              <p>一名极度乐观的悲观主义者</p>
            </div>
            <div>
              <h3>技术栈</h3>
              <ul class="skills-list">
                <li>HTML5 & CSS3</li>
                <li>JavaScript</li>
                <li>C++ & C</li>
                <li>Python</li>
                <li>Git & GitHub</li>
                <li>持续学习和完善技术栈中...</li>
              </ul>
            </div>
          </div>
        </section>
      </div>

      <div class="grid-two">
        <section id="contact" class="panel section-panel">
          <div class="section-header">
            <div>
              <span class="panel-kicker">Guestbook</span>
              <h2 class="section-title">留言板</h2>
            </div>
          </div>
          <div class="contact-card">
            <div class="section-copy">
              <p>欢迎在这里留下你的足迹、建议或任何想对我说的话，</p>
              <p><strong>邮箱：</strong>antemeridiem@foxmail.com</p>
              <p><strong>GitHub：</strong><a href="https://github.com/langhuanaibu" target="_blank">github.com/langhuanaibu</a></p>
            </div>
            <div id="twikoo-comments" class="panel" style="padding: 20px;"></div>
          </div>
        </section>

        <section id="friends" class="panel section-panel">
          <div class="section-header">
            <div>
              <span class="panel-kicker">Friends</span>
              <h2 class="section-title">友情链接</h2>
            </div>
          </div>
          <div class="friends-grid">
            <a href="https://www.cloudtide.xyz/" target="_blank" rel="noreferrer" class="friend-card">
              <img src="/images/friend-avatar.jpg" alt="晚风拾云的头像">
              <div>
                <h3 style="margin: 0 0 5px 0; font-size: 16px;">晚风拾云的博客</h3>
                <p style="font-size: 12px;">漫漫长路，原作清风伴君途</p>
              </div>
            </a>

            <a href="https://langhuanaibu.github.io/my-blog/" target="_blank" rel="noreferrer" class="friend-card">
              <img src="/images/my-avatar.jpg" alt="Aoitsuki 的头像">
              <div>
                <h3 style="margin: 0 0 5px 0; font-size: 16px;">Aoitsuki's Blog</h3>
                <p style="font-size: 12px;">乌幕屏，海相续...</p>
              </div>
            </a>

            <a href="https://labuladong.online/zh/" target="_blank" rel="noopener noreferrer" class="friend-card">
              <img src="https://api.dicebear.com/7.x/shapes/svg?seed=algo" alt="labuladong">
              <div>
                <h3 style="margin: 0 0 5px 0; font-size: 16px;">labuladong 的算法笔记</h3>
                <p style="font-size: 12px;">最高效的算法刷题解决方案</p>
              </div>
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    import { prepareWithSegments, layoutWithLines } from 'https://cdn.jsdelivr.net/npm/@chenglou/pretext@0.0.5/dist/layout.js';

    async function initLatestArticles() {
      let blogArticles = [];
      try {
        const response = await fetch('/api/getArticles', {
          method: 'GET',
          cache: 'no-store'
        });

        if (response.ok) {
          const data = await response.json();
          if (data && data.success) blogArticles = data.data;
        }
      } catch (error) {
        console.error('获取文章失败:', error);
      }

      blogArticles.sort((a, b) => new Date(b.date) - new Date(a.date));
      const latestThree = blogArticles.slice(0, 3);
      const latestArticlesContainer = document.getElementById('latest-articles');
      latestArticlesContainer.innerHTML = '';

      // 获取容器大致宽度用于文本测量，预设 300px 作为 fallback
      const containerWidth = latestArticlesContainer.clientWidth > 0 ? (latestArticlesContainer.clientWidth / 3 - 44) : 300;
      const font = '16px "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif';

      latestThree.forEach((article) => {
        const htmlContent = marked.parse(article.content || '');
        const contentText = htmlContent.replace(/<[^>]*>/g, '');
        const readTime = Math.ceil(contentText.length / 300) || 1;

        let excerpt = '';
        try {
          const prepared = prepareWithSegments(contentText, font);
          // 容器宽度，行高预估 28 (16 * 1.75)
          const { lines } = layoutWithLines(prepared, containerWidth, 28);
          const excerptLines = lines.slice(0, 3).map(l => l.text.trim());
          excerpt = excerptLines.join(' ');
          if (lines.length > 3) excerpt += '...';
        } catch (e) {
          // Fallback
          excerpt = contentText.substring(0, 100) + (contentText.length > 100 ? '...' : '');
        }

        latestArticlesContainer.innerHTML += `
          <article class="blog-card">
            <div class="blog-meta">
              <span>${article.date}</span>
              <span>约 ${readTime} 分钟阅读</span>
            </div>
            <h3 class="blog-title"><a href="/articles.html#${article.id}" class="blog-link">${article.title}</a></h3>
            <div class="blog-tags">
              <span class="panel-kicker" style="font-size: 0.72rem;">${article.category || '未分类'}</span>
            </div>
            <p class="blog-excerpt">${excerpt}</p>
            <a href="/articles.html#${article.id}" class="btn btn-secondary">阅读更多</a>
          </article>
        `;
      });

      if (!latestThree.length) {
        latestArticlesContainer.innerHTML = '<p class="panel-empty">暂时还没有文章，稍后再来看看。</p>';
      }

      const categoriesGrid = document.getElementById('dynamic-categories-grid');
      const existingCategories = new Set();
      const defaultCategories = ['技术学习', '数据结构与算法', '随笔'];

      blogArticles.forEach((article) => {
        if (article.category) existingCategories.add(article.category);
      });
      defaultCategories.forEach((category) => existingCategories.add(category));

      categoriesGrid.innerHTML = '';
      // 改变类别容器为相对定位以便实现瀑布流
      categoriesGrid.style.position = 'relative';
      categoriesGrid.style.display = 'block';

      const categoryMeta = {
        技术学习: { icon: '📚', desc: '记录自己的一些技术栈' },
        数据结构与算法: { icon: '🧠', desc: '修炼内功，提升算法思维' },
        随笔: { icon: '📝', desc: '日常感悟与折腾记录' }
      };

      // 瀑布流布局计算
      const colCount = window.innerWidth > 1100 ? 3 : 1;
      const gap = 18;
      const colWidth = categoriesGrid.clientWidth > 0 
        ? (categoriesGrid.clientWidth - gap * (colCount - 1)) / colCount 
        : 300;
      
      const colHeights = Array(colCount).fill(0);
      let masonryHTML = '';

      existingCategories.forEach((category) => {
        const meta = categoryMeta[category] || { icon: '🗂', desc: `关于 ${category} 的相关文章` };
        const displayName = category === '随笔' ? '生活随笔' : category;

        // 预估卡片高度: padding (44) + gap (14 * 2) + icon (1.8rem*1.75 ≈ 51) + title (1.17em*1.35 ≈ 26) + desc text
        let descHeight = 28;
        try {
          const prepared = prepareWithSegments(meta.desc, font);
          const { height } = layoutWithLines(prepared, colWidth - 44, 28);
          descHeight = height;
        } catch(e) {}

        // 加上一个小小的缓冲(如4px)防止不同浏览器字体渲染差异导致溢出
        const cardHeight = 44 + 28 + 51 + 26 + descHeight + 4;

        // 找到最矮的列
        let minColIdx = 0;
        for (let i = 1; i < colCount; i++) {
          if (colHeights[i] < colHeights[minColIdx]) {
            minColIdx = i;
          }
        }

        const top = colHeights[minColIdx];
        const left = minColIdx * (colWidth + gap);

        masonryHTML += `
          <a href="/articles.html?category=${encodeURIComponent(category)}" class="category-card" style="position: absolute; top: ${top}px; left: ${left}px; width: ${colWidth}px; height: ${cardHeight}px; box-sizing: border-box; overflow: hidden;">
            <div class="category-icon">${meta.icon}</div>
            <h3 class="category-name">${displayName}</h3>
            <p class="category-desc">${meta.desc}</p>
          </a>
        `;

        colHeights[minColIdx] += cardHeight + gap;
      });

      categoriesGrid.innerHTML = masonryHTML;
      categoriesGrid.style.height = Math.max(...colHeights) + 'px';
    }

    document.addEventListener('DOMContentLoaded', initLatestArticles);
    window.addEventListener('resize', () => {
      // 简单处理响应式：窗口大小改变时重新计算
      initLatestArticles();
    });
  </script>

  <Fragment slot="scripts">
    <script is:inline src="https://cdn.staticfile.net/twikoo/1.6.32/twikoo.all.min.js"></script>
    <script is:inline>
      twikoo.init({
        envId: 'https://twikoo.aoiblog.top',
        el: '#twikoo-comments',
        path: '/',
        lang: 'zh-CN'
      });
    </script>
    <script is:inline src="/script.js"></script>
  </Fragment>
</BaseLayout>
