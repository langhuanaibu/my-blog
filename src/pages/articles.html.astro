---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="我的文章 - 我的个人博客"
  description="Aoitsuki 的文章归档、分类与阅读页面。"
  isIndex={false}
  pageClass="page-articles"
  showTexture={true}
>
  <Fragment slot="head">
  </Fragment>

  <section class="page-shell article-page-shell">
      <div class="page-shell__inner article-page-grid">
        <aside class="panel panel-nav panel-nav--archive article-nav-panel">
          <div class="panel-heading">
            <span class="panel-kicker">Archive</span>
          <h1>我的文章</h1>
          <p>按时间、分类与关键词检索最近写下的内容。</p>
        </div>

          <div class="search-box paper-search">
            <input type="text" id="search-input" placeholder="搜索文章标题或内容..." />
          </div>

          <div class="category-filter paper-filters" id="category-filter-container">
            <button class="filter-btn active" data-category="all">全部</button>
          </div>

          <div id="articles-nav" class="article-nav-list">
            <p class="panel-empty">加载中...</p>
          </div>
        </aside>

        <article class="panel panel-content panel-content--reading article-content-panel">
          <div id="article-detail" class="article-detail-empty">
            <span class="panel-kicker">Reading</span>
            <h2>请选择一篇文章开始阅读</h2>
            <p class="desktop-only-text">从左侧列表中选择一篇文章，即可在中间查看完整内容。</p>
            <p class="mobile-only-text">点击下方导航栏的“文章”，在列表中选择一篇开始阅读。</p>
          </div>
        </article>

        <aside class="panel panel-toc panel-toc--outline article-toc-panel">
          <div class="panel-heading panel-heading--compact" style="display: flex; justify-content: space-between; align-items: flex-start; position: relative;">
            <div>
              <span class="panel-kicker">Outline</span>
              <h2>文章大纲</h2>
            </div>
          </div>
          <ul id="toc-list" class="toc-list">
            <li class="toc-item"><span class="panel-empty">暂无目录</span></li>
          </ul>
        </aside>
      </div> <!-- End page-shell__inner -->
      
    </section>

    <!-- Mobile Bottom Navigation -->
    <div class="mobile-overlay" id="mobile-overlay"></div>
    <div class="mobile-bottom-nav mobile-bottom-nav--reader">
      <button class="mobile-nav-btn" id="mobile-btn-articles">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
        <span>文章</span>
      </button>
      <button class="mobile-nav-btn" id="mobile-btn-toc">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
        <span>大纲</span>
      </button>
      <button class="mobile-nav-btn" id="mobile-btn-theme">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <span>主题</span>
      </button>
      <button class="mobile-nav-btn" id="mobile-btn-fullscreen">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
        <span id="fullscreen-text">全屏</span>
      </button>
      <button class="mobile-nav-btn" id="mobile-btn-top">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
        <span>顶部</span>
      </button>
    </div>

  </section>

  <Fragment slot="scripts">
    <script type="module" is:inline>
      let blogArticles = [];
      let activeArticleId = '';
      const articleDetails = new Map();
      const loadedScripts = new Map();
      const loadedStyles = new Set();
      let markedPromise = null;
      let prismPromise = null;
      let twikooPromise = null;

      function loadScript(src) {
        if (loadedScripts.has(src)) return loadedScripts.get(src);

        const promise = new Promise((resolve, reject) => {
          const existing = document.querySelector(`script[src="${src}"]`);
          if (existing) {
            existing.addEventListener('load', resolve, { once: true });
            existing.addEventListener('error', reject, { once: true });
            if (existing.dataset.loaded === 'true') resolve();
            return;
          }

          const script = document.createElement('script');
          script.src = src;
          script.async = true;
          script.onload = () => {
            script.dataset.loaded = 'true';
            resolve();
          };
          script.onerror = reject;
          document.head.appendChild(script);
        });

        loadedScripts.set(src, promise);
        return promise;
      }

      function loadStyle(href) {
        if (loadedStyles.has(href) || document.querySelector(`link[href="${href}"]`)) return;
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = href;
        document.head.appendChild(link);
        loadedStyles.add(href);
      }

      async function ensureMarked() {
        if (!markedPromise) {
          markedPromise = loadScript('https://cdn.jsdelivr.net/npm/marked/marked.min.js').then(() => window.marked);
        }
        return markedPromise;
      }

      async function ensurePrism() {
        if (!prismPromise) {
          loadStyle('https://cdn.staticfile.net/prism-themes/1.9.0/prism-vsc-dark-plus.min.css');
          loadStyle('https://cdn.staticfile.net/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.css');
          loadStyle('https://cdn.staticfile.net/prism/1.29.0/plugins/toolbar/prism-toolbar.min.css');

          prismPromise = loadScript('https://cdn.staticfile.net/prism/1.29.0/prism.min.js')
            .then(() => Promise.all([
              loadScript('https://cdn.staticfile.net/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js'),
              loadScript('https://cdn.staticfile.net/prism/1.29.0/plugins/line-numbers/prism-line-numbers.min.js'),
              loadScript('https://cdn.staticfile.net/prism/1.29.0/plugins/toolbar/prism-toolbar.min.js'),
              loadScript('https://cdn.staticfile.net/prism/1.29.0/plugins/show-language/prism-show-language.min.js'),
              loadScript('https://cdn.staticfile.net/prism/1.29.0/plugins/copy-to-clipboard/prism-copy-to-clipboard.min.js')
            ]))
            .then(() => {
              if (window.Prism?.plugins?.autoloader) {
                window.Prism.plugins.autoloader.languages_path = 'https://cdn.staticfile.net/prism/1.29.0/components/';
              }
              return window.Prism;
            });
        }
        return prismPromise;
      }

      async function ensureTwikoo() {
        if (!twikooPromise) {
          twikooPromise = loadScript('https://cdn.staticfile.net/twikoo/1.6.32/twikoo.all.min.js').then(() => window.twikoo);
        }
        return twikooPromise;
      }

      async function loadArticles() {
        try {
          const response = await fetch('/api/getArticles?view=list', { method: 'GET' });
          if (!response.ok) throw new Error(`请求失败: ${response.status}`);

          const data = await response.json();
          if (!data || !data.success || !Array.isArray(data.data)) {
            throw new Error('API 返回格式错误');
          }

          blogArticles = data.data.sort((a, b) => new Date(b.date) - new Date(a.date));
          window.blogArticles = blogArticles;
          renderCategoryFilters(blogArticles);
          renderArticlesList();

          const hash = window.location.hash;
          if (hash) showArticle(hash.substring(1));
        } catch (error) {
          console.error('加载文章失败:', error);
          const nav = document.getElementById('articles-nav');
          if (nav) nav.innerHTML = '<p class="panel-empty">加载失败，请检查网络后刷新重试。</p>';
        }
      }

      async function loadArticleDetail(articleId) {
        if (articleDetails.has(articleId)) return articleDetails.get(articleId);

        const response = await fetch(`/api/getArticles?view=detail&id=${encodeURIComponent(articleId)}`, { method: 'GET' });
        if (!response.ok) throw new Error(`请求失败: ${response.status}`);

        const data = await response.json();
        if (!data || !data.success || !data.data) {
          throw new Error('API 返回格式错误');
        }

        articleDetails.set(articleId, data.data);
        return data.data;
      }

      function renderCategoryFilters(articles) {
        const categoryContainer = document.getElementById('category-filter-container');
        const categories = new Set();

        articles.forEach((article) => {
          if (article.category) categories.add(article.category);
        });

        categoryContainer.innerHTML = '<button class="filter-btn active" data-category="all">全部</button>';

        categories.forEach((cat) => {
          const btn = document.createElement('button');
          btn.className = 'filter-btn';
          btn.dataset.category = cat;
          btn.textContent = cat === '随笔' ? '生活随笔' : cat;
          categoryContainer.appendChild(btn);
        });

        bindFilterEvents();
      }

      let virtualListState = { items: [], totalHeight: 0, rendered: new Set() };

      function estimateTitleHeight(title, isRead, containerWidth) {
        const textLength = String(title || '').length + (isRead ? 2 : 0);
        const charsPerLine = Math.max(8, Math.floor((containerWidth - 20) / 16));
        return Math.max(24, Math.ceil(textLength / charsPerLine) * 24);
      }

      function closeAllMobilePanels() {
        document.querySelector('.article-nav-panel')?.classList.remove('active');
        document.querySelector('.article-toc-panel')?.classList.remove('active');
        document.getElementById('mobile-overlay')?.classList.remove('active');
        document.getElementById('mobile-btn-articles')?.classList.remove('active');
        document.getElementById('mobile-btn-toc')?.classList.remove('active');
        document.body.classList.remove('mobile-panel-open');
      }

      function renderArticlesList(articlesToRender) {
        const articlesNav = document.getElementById('articles-nav');
        const listToRender = articlesToRender || blogArticles;

        if (!listToRender.length) {
          articlesNav.innerHTML = '<p class="panel-empty">暂无文章</p>';
          articlesNav.style.height = 'auto';
          return;
        }

        const readHistory = JSON.parse(localStorage.getItem('readHistory') || '{}');
        const gap = 12;
        const paddingY = 28;
        const metaHeight = 20;
        const dateHeight = 20;
        const innerGap = 12;
        const containerWidth = articlesNav.clientWidth > 0 ? articlesNav.clientWidth - 32 : 240;

        let currentTop = 0;
        virtualListState.items = listToRender.map(article => {
          const isRead = Boolean(readHistory[article.id]);
          const readBadge = isRead ? '<span class="article-item-read">已读</span>' : '';
          const titleHeight = estimateTitleHeight(article.title, isRead, containerWidth);
          const itemHeight = paddingY + innerGap + metaHeight + dateHeight + titleHeight + 8;
          const itemTop = currentTop;
          currentTop += itemHeight + gap;

          return {
            article,
            readBadge,
            top: itemTop,
            height: itemHeight,
            bottom: itemTop + itemHeight,
            id: article.id
          };
        });

        virtualListState.totalHeight = currentTop - gap;
        articlesNav.style.position = 'relative';
        articlesNav.style.height = virtualListState.totalHeight + 'px';
        articlesNav.innerHTML = '';
        virtualListState.rendered.clear();

        updateVirtualList();
      }

      function updateVirtualList() {
        const articlesNav = document.getElementById('articles-nav');
        if (!articlesNav || virtualListState.items.length === 0) return;

        const navRect = articlesNav.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const navTopInViewport = navRect.top;
        const visibleTop = Math.max(0, -navTopInViewport - 1200);
        const visibleBottom = visibleTop + windowHeight + 1800;

        const itemsToRender = virtualListState.items.filter(item =>
          item.bottom >= visibleTop && item.top <= visibleBottom
        );

        const newRenderedIds = new Set(itemsToRender.map(item => item.id));

        Array.from(articlesNav.children).forEach(child => {
          const id = child.dataset.id;
          if (!newRenderedIds.has(id)) {
            articlesNav.removeChild(child);
            virtualListState.rendered.delete(id);
          }
        });

        itemsToRender.forEach(item => {
          if (!virtualListState.rendered.has(item.id)) {
            const div = document.createElement('div');
            div.className = 'article-item';
            div.dataset.id = item.id;
            div.style.position = 'absolute';
            div.style.top = item.top + 'px';
            div.style.left = '0';
            div.style.right = '0';

            const activeClass = activeArticleId === item.id || window.location.hash.substring(1) === item.id ? 'active' : '';
            div.innerHTML = `
              <a href="#${item.id}" class="article-link ${activeClass}" data-id="${item.id}">
                <span class="article-item-meta">${item.article.category || '未分类'}</span>
                <span class="article-item-title">${item.article.title} ${item.readBadge}</span>
                <span class="article-item-date">${item.article.date}</span>
              </a>
            `;

            const link = div.querySelector('.article-link');
            link.addEventListener('click', (e) => {
              e.preventDefault();
              if (window.innerWidth <= 1100) closeAllMobilePanels();
              document.querySelectorAll('.article-link').forEach((a) => a.classList.remove('active'));
              link.classList.add('active');
              showArticle(item.id);
              history.pushState(null, '', '#' + item.id);
              setTimeout(updateVirtualList, 50);
              setTimeout(updateVirtualList, 300);
            });

            articlesNav.appendChild(div);
            virtualListState.rendered.add(item.id);
          }
        });
      }

      window.addEventListener('scroll', () => {
        if (!window._isScrolling) {
          window._isScrolling = true;
          window.requestAnimationFrame(() => {
            updateVirtualList();
            window._isScrolling = false;
          });
        }
      });

      async function showArticle(articleId) {
        const articleDetail = document.getElementById('article-detail');
        const summary = blogArticles.find((item) => item.id === articleId);

        if (!summary) {
          articleDetail.innerHTML = '<h2>文章未找到</h2>';
          return;
        }

        activeArticleId = articleId;
        window.activeArticleId = articleId;
        document.querySelectorAll('.article-link').forEach((a) => {
          a.classList.toggle('active', a.dataset.id === articleId);
        });

        articleDetail.innerHTML = '<p class="panel-empty">加载中...</p>';

        try {
          const [article, marked] = await Promise.all([
            loadArticleDetail(articleId),
            ensureMarked()
          ]);

          if (activeArticleId !== articleId) return;

          const normalizedContent = (article.content || '')
            .replace(/src=(["'])images\//g, 'src=$1/images/')
            .replace(/src=(["'])\.\/images\//g, 'src=$1/images/');

          articleDetail.innerHTML = `
            <header class="article-header">
              <span class="panel-kicker">Post</span>
              <h1 class="article-title">${article.title}</h1>
              <div class="article-meta">
                <span>发布日期：${article.date}</span>
                <span>分类：${article.category || '未分类'}</span>
                <span class="article-views">
                  阅读量：<span id="twikoo_visitors" class="twikoo_visitors" data-flag-title="文章阅读量">0</span>
                </span>
                <span class="article-full-read" id="full-read-count-display">
                  完整阅读：<span>获取中...</span>
                </span>
              </div>
            </header>
            <div id="read-progress-container" class="read-progress-container">
              <div id="read-progress-bar" class="read-progress-bar"></div>
            </div>
            <div id="read-progress-text" class="read-progress-text">阅读进度: 0%</div>
            <div id="article-content" class="article-content prose" data-article-id="${articleId}">
              ${marked.parse(normalizedContent)}
            </div>
            <div class="article-modify">
              <p>最后修改日期：<span>${article.modifyDate || article.date}</span></p>
            </div>
            <section class="article-comments">
              <h3>评论区</h3>
              <div id="twikoo-comments"></div>
            </section>
          `;

          loadTwikoo(articleId);
          generateTOC();
          initReadProgress();
          fetchFullReadCount(articleId);

          const articleContent = document.getElementById('article-content');
          articleContent?.querySelectorAll('img').forEach((img) => {
            img.loading = 'lazy';
            img.decoding = 'async';
          });
          articleContent?.querySelectorAll('pre').forEach((pre) => {
            pre.classList.add('mac-style-code');
          });

          if (articleContent?.querySelector('pre code, code[class*="language-"]')) {
            const Prism = await ensurePrism();
            if (activeArticleId === articleId && Prism) {
              Prism.highlightAllUnder(articleContent);
            }
          }
        } catch (error) {
          console.error('加载文章详情失败:', error);
          if (activeArticleId === articleId) {
            articleDetail.innerHTML = '<p class="panel-empty">加载失败，请检查网络后重试。</p>';
          }
        }
      }

      window.showArticle = showArticle;

      function generateTOC() {
        const content = document.getElementById('article-content');
        const tocList = document.getElementById('toc-list');
        if (!content || !tocList) return;

        const headings = content.querySelectorAll('h2, h3');
        tocList.innerHTML = '';

        if (!headings.length) {
          tocList.innerHTML = '<li class="toc-item"><span class="panel-empty">暂无目录</span></li>';
          return;
        }

        headings.forEach((heading, index) => {
          const id = `heading-${index}`;
          heading.id = id;

          const li = document.createElement('li');
          li.className = `toc-item toc-${heading.tagName.toLowerCase()}`;

          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = heading.innerText;
          a.addEventListener('click', (e) => {
            e.preventDefault();
            const headerHeight = document.querySelector('.site-header')?.offsetHeight || 90;
            const targetPosition = heading.getBoundingClientRect().top + window.scrollY - headerHeight - 20;

            if (window.innerWidth <= 1100 && document.body.classList.contains('mobile-panel-open')) {
              const panelToc = document.querySelector('.article-toc-panel');
              const mobileOverlay = document.getElementById('mobile-overlay');
              const btnToc = document.getElementById('mobile-btn-toc');

              if(panelToc) panelToc.classList.remove('active');
              if(mobileOverlay) mobileOverlay.classList.remove('active');
              if(btnToc) btnToc.classList.remove('active');
              document.body.classList.remove('mobile-panel-open');

              setTimeout(() => {
                 const newTargetPosition = heading.getBoundingClientRect().top + window.scrollY - headerHeight - 20;
                 window.scrollTo({
                  top: newTargetPosition,
                  behavior: 'smooth'
                 });
              }, 300);
            } else {
              window.scrollTo({
                top: targetPosition,
                behavior: 'smooth'
              });
            }

            document.querySelectorAll('.toc-item a').forEach((link) => link.classList.remove('active'));
            a.classList.add('active');
          });

          li.appendChild(a);
          tocList.appendChild(li);
        });

        tocList.querySelector('a')?.classList.add('active');
      }

      function fetchFullReadCount(articleId) {
        const displaySpan = document.querySelector('#full-read-count-display span');
        if (!displaySpan) return;

        const readHistory = JSON.parse(localStorage.getItem('readHistory') || '{}');
        if (readHistory[articleId]) {
          displaySpan.innerHTML = '<span class="read-state read-state--done">已完整阅读</span>';
        } else {
          displaySpan.innerHTML = '<span class="read-state read-state--pending">正在阅读中</span>';
        }
      }

      function markAsRead(articleId) {
        const readHistory = JSON.parse(localStorage.getItem('readHistory') || '{}');
        if (readHistory[articleId]) return;

        readHistory[articleId] = Date.now();
        localStorage.setItem('readHistory', JSON.stringify(readHistory));

        const currentLink = document.querySelector(`.article-link[data-id="${articleId}"] .article-item-title`);
        if (currentLink && !currentLink.innerHTML.includes('已读')) {
          currentLink.innerHTML += ' <span class="article-item-read">已读</span>';
        }

        const displaySpan = document.querySelector('#full-read-count-display span');
        if (displaySpan) {
          displaySpan.innerHTML = '<span class="read-state read-state--done">已完整阅读</span>';
        }
      }

      function initReadProgress() {
        const progressContainer = document.getElementById('read-progress-container');
        const progressText = document.getElementById('read-progress-text');
        const progressBar = document.getElementById('read-progress-bar');

        if (progressContainer && progressText && progressBar) {
          progressContainer.style.display = 'block';
          progressText.style.display = 'block';
          progressBar.style.width = '0%';
          progressText.innerText = '阅读进度: 0%';
          window.dispatchEvent(new Event('scroll'));
        }
      }

      function getFilteredArticles() {
        const keyword = document.getElementById('search-input')?.value.toLowerCase().trim() || '';
        const activeFilter = document.querySelector('.filter-btn.active');
        const category = activeFilter?.dataset.category || 'all';
        let filtered = blogArticles;

        if (category !== 'all') {
          filtered = filtered.filter((article) => article.category === category);
        }

        if (keyword) {
          filtered = filtered.filter((article) => {
            const titleMatch = (article.title || '').toLowerCase().includes(keyword);
            const excerptMatch = (article.excerpt || '').toLowerCase().includes(keyword);
            return titleMatch || excerptMatch;
          });
        }

        return filtered;
      }

      function bindFilterEvents() {
        document.querySelectorAll('.filter-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('.filter-btn').forEach((button) => button.classList.remove('active'));
            btn.classList.add('active');
            renderArticlesList(getFilteredArticles());
          });
        });
      }

      async function loadTwikoo(articleId) {
        setTimeout(async () => {
          const container = document.getElementById('twikoo-comments');
          if (!container) return;
          container.innerHTML = '';
          const twikoo = await ensureTwikoo();
          if (!twikoo) return;
          twikoo.init({
            envId: 'https://twikoo.aoiblog.top',
            el: '#twikoo-comments',
            path: articleId,
            lang: 'zh-CN'
          });
        }, 100);
      }

      window.addEventListener('scroll', () => {
        const content = document.getElementById('article-content');
        if (!content) return;

        const headings = content.querySelectorAll('h2, h3');
        const headerHeight = document.querySelector('.site-header')?.offsetHeight || 90;
        let currentId = '';

        headings.forEach((heading) => {
          const rect = heading.getBoundingClientRect();
          if (rect.top <= headerHeight + 50) currentId = heading.id;
        });

        if (!currentId && headings.length) currentId = headings[0].id;

        if (currentId) {
          document.querySelectorAll('.toc-item a').forEach((a) => {
            a.classList.toggle('active', a.getAttribute('href') === `#${currentId}`);
          });
        }

        const progressBar = document.getElementById('read-progress-bar');
        const progressText = document.getElementById('read-progress-text');
        if (!progressBar || !progressText) return;

        const rect = content.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const topDist = -rect.top + headerHeight;
        const totalScrollable = rect.height - windowHeight + headerHeight;

        let progress = 0;
        if (topDist > 0 && totalScrollable > 0) {
          progress = Math.min(100, Math.max(0, Math.round((topDist / totalScrollable) * 100)));
        } else if (topDist > 0 && totalScrollable <= 0) {
          progress = 100;
        }

        progressBar.style.width = `${progress}%`;
        progressText.innerText = `阅读进度: ${progress}%`;

        if (progress >= 90) markAsRead(content.dataset.articleId);
      });

      document.addEventListener('DOMContentLoaded', async () => {
        await loadArticles();

        const focusBtn = document.getElementById('focus-mode-toggle');
        if (focusBtn) {
          focusBtn.addEventListener('click', () => {
            const isActive = document.body.classList.toggle('focus-mode-active');
            if (isActive) {
              focusBtn.classList.add('active-state');
              focusBtn.style.color = 'var(--accent)';
              focusBtn.style.borderColor = 'var(--accent)';
              const toolsPanel = document.getElementById('article-tools-panel');
              if (toolsPanel) toolsPanel.classList.remove('active');
            } else {
              focusBtn.classList.remove('active-state');
              focusBtn.style.color = '';
              focusBtn.style.borderColor = '';
              const toolsPanel = document.getElementById('article-tools-panel');
              if (toolsPanel) toolsPanel.classList.remove('active');
            }
          });
        }

        const tocBtn = document.getElementById('toc-mode-toggle');
        if (tocBtn) {
          tocBtn.addEventListener('click', () => {
            const isHidden = document.body.classList.toggle('hide-toc-active');
            if (isHidden) {
              tocBtn.classList.add('active-state');
              tocBtn.style.color = 'var(--accent)';
              tocBtn.style.borderColor = 'var(--accent)';
              const toolsPanel = document.getElementById('article-tools-panel');
              if (toolsPanel) toolsPanel.classList.remove('active');
            } else {
              tocBtn.classList.remove('active-state');
              tocBtn.style.color = '';
              tocBtn.style.borderColor = '';
              const toolsPanel = document.getElementById('article-tools-panel');
              if (toolsPanel) toolsPanel.classList.remove('active');
            }
          });
        }

        const urlParams = new URLSearchParams(window.location.search);
        const categoryFilter = urlParams.get('category');
        if (categoryFilter) {
          document.querySelectorAll('.filter-btn').forEach((btn) => {
            if (btn.dataset.category === categoryFilter) btn.click();
          });
        }

        const searchInput = document.getElementById('search-input');
        if (searchInput) {
          searchInput.addEventListener('input', () => {
            renderArticlesList(getFilteredArticles());
          });
        }

        const mobileOverlay = document.getElementById('mobile-overlay');
        const btnArticles = document.getElementById('mobile-btn-articles');
        const btnToc = document.getElementById('mobile-btn-toc');
        const btnTheme = document.getElementById('mobile-btn-theme');
        const btnFullscreen = document.getElementById('mobile-btn-fullscreen');
        const btnTop = document.getElementById('mobile-btn-top');
        const panelArticles = document.querySelector('.article-nav-panel');
        const panelToc = document.querySelector('.article-toc-panel');

        if (btnArticles && btnToc) {
          btnArticles.addEventListener('click', () => {
            if (panelArticles.classList.contains('active')) {
              closeAllMobilePanels();
            } else {
              closeAllMobilePanels();
              panelArticles.classList.add('active');
              mobileOverlay.classList.add('active');
              btnArticles.classList.add('active');
              document.body.classList.add('mobile-panel-open');
            }
          });

          btnToc.addEventListener('click', () => {
            if (panelToc.classList.contains('active')) {
              closeAllMobilePanels();
            } else {
              closeAllMobilePanels();
              panelToc.classList.add('active');
              mobileOverlay.classList.add('active');
              btnToc.classList.add('active');
              document.body.classList.add('mobile-panel-open');
            }
          });

          mobileOverlay.addEventListener('click', closeAllMobilePanels);

          panelArticles.addEventListener('click', (e) => {
            if (e.target.closest('a')) {
              closeAllMobilePanels();
            }
          });
          panelToc.addEventListener('click', (e) => {
            if (e.target.closest('a')) {
              closeAllMobilePanels();
            }
          });

          btnTheme.addEventListener('click', () => {
            const themeToggle = document.getElementById('theme-toggle');
            if (themeToggle) themeToggle.click();
          });

          if (btnFullscreen) {
            btnFullscreen.addEventListener('click', () => {
              const isHidden = document.body.classList.toggle('mobile-header-hidden');
              const fsText = document.getElementById('fullscreen-text');
              const fsSvg = btnFullscreen.querySelector('svg');
              if (isHidden) {
                fsText.textContent = '退出全屏';
                btnFullscreen.classList.add('active');
                fsSvg.innerHTML = '<path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"></path>';
              } else {
                fsText.textContent = '全屏';
                btnFullscreen.classList.remove('active');
                fsSvg.innerHTML = '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>';
              }
            });
          }

          btnTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      });
    </script>
    <script is:inline src="/script.js"></script>
  </Fragment>
  <Fragment slot="floating-menu-extra">
    <button id="toc-mode-toggle" class="floating-btn action-btn" type="button" aria-label="隐藏大纲" title="隐藏大纲">纲</button>
    <button id="focus-mode-toggle" class="floating-btn action-btn" type="button" aria-label="专注阅读" title="专注阅读">专</button>
  </Fragment>
</BaseLayout>
